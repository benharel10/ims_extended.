generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Warehouse {
  id                   Int             @id @default(autoincrement())
  name                 String          @unique
  location             String?
  type                 String          @default("Standard")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  stocks               ItemStock[]
  productionFrom       ProductionRun[] @relation("ProductionFrom")
  productionTo         ProductionRun[] @relation("ProductionTo")
  originShipments      Shipment[]      @relation("Origin")
  destinationShipments Shipment[]      @relation("Destination")
}

model ItemStock {
  id          Int       @id @default(autoincrement())
  itemId      Int
  warehouseId Int
  quantity    Decimal   @default(0) @db.Decimal(10, 3)
  location    String?
  item        Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([itemId, warehouseId])
}

model Item {
  id                     Int                @id @default(autoincrement())
  sku                    String             @unique
  icountId               Int?               @unique
  name                   String
  description            String?
  type                   String             @default("Raw")
  minStock               Decimal            @default(0) @db.Decimal(10, 3)
  currentStock           Decimal            @default(0) @db.Decimal(10, 3)
  cost                   Float              @default(0.0)
  price                  Float              @default(0.0)
  isSerialized           Boolean            @default(false)
  revision               String?
  warehouse              String?
  brand                  String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  uom                    String             @default("Units")
  deletedAt              DateTime?
  version                Int                @default(0)
  allocatedStock         Decimal            @default(0) @db.Decimal(10, 3)
  inspectionTemplateName String?
  inspectionTemplateUrl  String?
  childBOMs              BOM[]              @relation("Child")
  parentBOMs             BOM[]              @relation("Parent")
  externalMappings       ExternalMapping[]
  inspectionRecords      InspectionRecord[]
  stocks                 ItemStock[]
  poLines                POLine[]
  packageItems           PackageItem[]
  productionRuns         ProductionRun[]
  salesLines             SalesLine[]
  salesOrders            SalesOrder[]
  serialized             SerializedItem[]

  @@index([deletedAt])
  @@index([sku])
  @@index([name])
  @@index([createdAt])
}

model BOM {
  id        Int       @id @default(autoincrement())
  parentId  Int
  childId   Int
  quantity  Decimal   @default(1.0) @db.Decimal(10, 3)
  deletedAt DateTime?
  child     Item      @relation("Child", fields: [childId], references: [id], onDelete: Cascade)
  parent    Item      @relation("Parent", fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@index([deletedAt])
}

model SerializedItem {
  id              Int              @id @default(autoincrement())
  sn              String           @unique
  itemId          Int
  status          String           @default("InStock")
  parentSnId      Int?
  productionRunId Int?
  assembledAt     DateTime?
  soldAt          DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  packageItems    PackageItem[]
  item            Item             @relation(fields: [itemId], references: [id], onDelete: Cascade)
  parent          SerializedItem?  @relation("Genealogy", fields: [parentSnId], references: [id])
  children        SerializedItem[] @relation("Genealogy")
  productionRun   ProductionRun?   @relation(fields: [productionRunId], references: [id], onDelete: Cascade)
}

model PurchaseOrder {
  id                   Int                @id @default(autoincrement())
  poNumber             String             @unique
  supplier             String
  status               String             @default("Draft")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  leadTimeDays         Int?
  salesOrderId         Int?
  shippingCost         Float?             @default(0.0)
  pendingManualMapping Boolean            @default(false)
  totalCost            Float?             @default(0.0)
  deliveredAt          DateTime?
  dueDate              DateTime?
  orderDate            DateTime?
  inspectionRecords    InspectionRecord[]
  lines                POLine[]
  salesOrder           SalesOrder?        @relation(fields: [salesOrderId], references: [id])

  @@index([status])
  @@index([createdAt])
}

model POLine {
  id           Int           @id @default(autoincrement())
  poId         Int
  itemId       Int?
  quantity     Int
  received     Int           @default(0)
  unitCost     Float
  newItemName  String?
  newItemSku   String?
  isAutoMapped Boolean       @default(false)
  item         Item?         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  po           PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
}

model SalesOrder {
  id                  Int             @id @default(autoincrement())
  soNumber            String          @unique
  customer            String
  status              String          @default("Draft")
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  productionRunId     Int?
  itemId              Int?
  quantity            Int?
  isAllocated         Boolean         @default(false)
  customerOrderNumber String?
  productionRuns      ProductionRun[] @relation("SalesOrderProduction")
  purchaseOrders      PurchaseOrder[]
  lines               SalesLine[]
  item                Item?           @relation(fields: [itemId], references: [id])
  productionRun       ProductionRun?  @relation(fields: [productionRunId], references: [id])
  shipments           Shipment[]

  @@index([status])
  @@index([createdAt])
}

model SalesLine {
  id        Int        @id @default(autoincrement())
  soId      Int
  itemId    Int
  quantity  Int
  shipped   Int        @default(0)
  unitPrice Float
  item      Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  so        SalesOrder @relation(fields: [soId], references: [id], onDelete: Cascade)
}

model ICountSyncLog {
  id         Int      @id @default(autoincrement())
  entityType String
  entityId   Int
  action     String
  status     String
  message    String?
  timestamp  DateTime @default(now())
}

model Shipment {
  id              Int         @id @default(autoincrement())
  shipmentNo      String      @unique
  soId            Int?
  type            String      @default("Outbound")
  fromWarehouseId Int?
  toWarehouseId   Int?
  carrier         String?
  trackingNo      String?
  status          String      @default("Draft")
  shipDate        DateTime?
  receiveDate     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  destination     String?
  packages        Package[]
  fromWarehouse   Warehouse?  @relation("Origin", fields: [fromWarehouseId], references: [id])
  salesOrder      SalesOrder? @relation(fields: [soId], references: [id])
  toWarehouse     Warehouse?  @relation("Destination", fields: [toWarehouseId], references: [id])
}

model Package {
  id         Int           @id @default(autoincrement())
  shipmentId Int
  type       String        @default("Box")
  weight     Float?
  dimensions String?
  trackingNo String?
  shipment   Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  items      PackageItem[]
}

model PackageItem {
  id               Int             @id @default(autoincrement())
  packageId        Int
  itemId           Int
  quantity         Int
  serializedItemId Int?
  item             Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)
  package          Package         @relation(fields: [packageId], references: [id], onDelete: Cascade)
  serializedItem   SerializedItem? @relation(fields: [serializedItemId], references: [id])
}

model ProductionRun {
  id              Int              @id @default(autoincrement())
  itemId          Int
  quantity        Decimal          @db.Decimal(10, 3)
  status          String           @default("Completed")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  fromWarehouseId Int?
  toWarehouseId   Int?
  salesOrderId    Int?
  fromWarehouse   Warehouse?       @relation("ProductionFrom", fields: [fromWarehouseId], references: [id])
  item            Item             @relation(fields: [itemId], references: [id], onDelete: Cascade)
  salesOrder      SalesOrder?      @relation("SalesOrderProduction", fields: [salesOrderId], references: [id])
  toWarehouse     Warehouse?       @relation("ProductionTo", fields: [toWarehouseId], references: [id])
  salesOrders     SalesOrder[]
  serializedItems SerializedItem[]
}

model User {
  id                Int                @id @default(autoincrement())
  email             String             @unique
  password          String
  name              String?
  role              String             @default("Warehouse")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  inspectionRecords InspectionRecord[]
  systemLogs        SystemLog[]

  @@index([email])
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  entity    String
  entityId  Int?
  details   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

/// Stores technical error details for debugging — errors shown to users are always friendly messages
model SystemError {
  id        Int      @id @default(autoincrement())
  context   String
  message   String
  stack     String?
  userId    Int?
  createdAt DateTime @default(now())
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WebhookError {
  id        Int      @id @default(autoincrement())
  source    String   @default("iCount")
  payload   String
  error     String
  createdAt DateTime @default(now())
}

model ExternalMapping {
  id             Int      @id @default(autoincrement())
  externalName   String?
  externalSku    String
  source         String   @default("iCount")
  internalItemId Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  item           Item     @relation(fields: [internalItemId], references: [id], onDelete: Cascade)

  @@unique([externalSku, source])
}

model InspectionRecord {
  id          Int            @id @default(autoincrement())
  itemId      Int
  poId        Int?
  fileName    String
  fileData    String
  status      String         @default("Pass")
  notes       String?
  inspectorId Int
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  inspector   User           @relation(fields: [inspectorId], references: [id])
  item        Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  po          PurchaseOrder? @relation(fields: [poId], references: [id])

  @@index([itemId])
  @@index([poId])
}
